# Default example values.
# For daily development, prefer a hosted staging project copied into app/.env.local.staging.
# For isolated schema work, use app/.env.local.local-supabase.

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Production Supabase (only needed for scripts that sync staging → prod,
# e.g. scripts/sync-curator-notes-to-prod.ts). Leave unset for normal dev.
PROD_SUPABASE_URL=https://your-production-project.supabase.co
PROD_SUPABASE_SERVICE_KEY=your-prod-service-role-key

# AWS Configuration
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=digital-grimoire-library

# Claude API (for AI reasoning)
CLAUDE_API_KEY=your-claude-api-key

# OpenRouter API (for text, JSON, vision metadata, and Parallax generation)
OPENROUTER_API_KEY=your-openrouter-api-key
# Live free model list: https://openrouter.ai/models?max_price=0
# Alternates: openai/gpt-oss-120b:free, qwen/qwen3-next-80b-a3b-instruct:free, google/gemma-4-31b-it:free
OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free
OPENROUTER_METADATA_MODEL=deepseek/deepseek-v4-flash:free
OPENROUTER_APP_TITLE=Prismarium

# OpenAI API (still used for embeddings and Whisper transcription)
OPENAI_API_KEY=your-openai-api-key

# Mistral API (used for PDF OCR — ~$1 per 1000 pages, handles scanned PDFs)
# Get a key at https://console.mistral.ai/
MISTRAL_API_KEY=your-mistral-api-key
# Optional: override the OCR model (default: mistral-ocr-latest)
# MISTRAL_OCR_MODEL=mistral-ocr-latest

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
