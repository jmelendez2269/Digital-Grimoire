# Default example values.
# For daily development, prefer a hosted staging project copied into app/.env.local.staging.
# For isolated schema work, use app/.env.local.local-supabase.

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AWS Configuration
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=digital-grimoire-library

# Claude API (for AI reasoning)
CLAUDE_API_KEY=your-claude-api-key

# OpenAI API (for embeddings)
OPENAI_API_KEY=your-openai-api-key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
